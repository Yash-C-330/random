# ============================================================
# Multi-Agent n8n System — Environment Variables
# Copy to .env and fill in real values before starting n8n.
# NEVER commit a populated .env to source control.
# ============================================================

# ─── n8n Core ────────────────────────────────────────────────
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=http
# For production TLS termination, set https and provide certs:
# N8N_SSL_KEY=/etc/n8n/ssl/privkey.pem
# N8N_SSL_CERT=/etc/n8n/ssl/fullchain.pem
WEBHOOK_URL=http://localhost:5678
N8N_ENCRYPTION_KEY=CHANGE_ME_32_CHAR_RANDOM_STRING__

# ─── Supabase Direct Postgres (n8n Postgres node) ────────────
# Preferred: direct DB connection bypasses PostgREST/RLS
SUPABASE_DB_HOST=db.YOUR_PROJECT_REF.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=n8n_agent
SUPABASE_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
SUPABASE_DB_SSL=true
# sslmode is set in the n8n Postgres credential as "require"

# ─── Supabase REST / PostgREST (optional, server-side only) ──
# Only needed if you choose to use Supabase HTTP nodes instead
# of direct Postgres. Use service_role key — NEVER anon key.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.CHANGE_ME

# ─── YouTube Data API v3 ─────────────────────────────────────
YOUTUBE_API_KEY=AIza_CHANGE_ME

# ─── X / Twitter v2 (optional) ───────────────────────────────
TWITTER_BEARER_TOKEN=AAAAAAAAAAAAAAAAAAAAAxx_CHANGE_ME

# ─── Apify (TikTok Scraper) ──────────────────────────────────
APIFY_TOKEN=apify_api_CHANGE_ME
APIFY_TIKTOK_ACTOR_ID=clockworks~tiktok-scraper

# ─── Reddit (Script App OAuth) ───────────────────────────────
REDDIT_CLIENT_ID=CHANGE_ME
REDDIT_CLIENT_SECRET=CHANGE_ME
REDDIT_USERNAME=CHANGE_ME
REDDIT_PASSWORD=CHANGE_ME
REDDIT_USER_AGENT=n8n-multiagent/1.0 (by /u/CHANGE_ME)

# ─── Meta Ads Library (optional) ─────────────────────────────
META_APP_ID=CHANGE_ME
META_APP_SECRET=CHANGE_ME
META_ACCESS_TOKEN=CHANGE_ME_LONG_LIVED_USER_ACCESS_TOKEN

# ─── Anthropic (Claude) ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_MAX_TOKENS=2000
ANTHROPIC_TEMPERATURE=0.3

# ─── Notion ──────────────────────────────────────────────────
NOTION_API_KEY=secret_CHANGE_ME
# The Notion database that the Report Writer Agent creates pages in:
NOTION_DATABASE_ID=CHANGE_ME_32_CHAR_DATABASE_ID
# Optional: parent page for new databases created by the agent:
NOTION_PARENT_PAGE_ID=CHANGE_ME

# ─── Slack (optional) ────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE/ME/NOW
SLACK_CHANNEL=#research-alerts

# ─── Feature Toggles ─────────────────────────────────────────
ENABLE_YOUTUBE=true
ENABLE_TWITTER=false
ENABLE_TIKTOK=true
ENABLE_REDDIT=true
ENABLE_META_ADS=false
ENABLE_NOTION=true
ENABLE_SLACK=false

# ─── Orchestration Tuning ────────────────────────────────────
MAX_ITEMS_DEFAULT=50
BATCH_SIZE=10
RATE_LIMIT_DELAY_MS=1200
COORDINATOR_POLL_INTERVAL_SECONDS=30
AGENT_POLL_INTERVAL_SECONDS=20
MESSAGE_RETRY_MAX=3
MESSAGE_RETRY_JITTER_MS=2000

# ─── SaaS API ────────────────────────────────────────────────
# A strong random key used to authenticate inbound webhook calls
SAAS_API_KEY=CHANGE_ME_STRONG_RANDOM_STRING

# ─── Optional: SerpAPI / NewsAPI ─────────────────────────────
SERPAPI_KEY=CHANGE_ME
NEWSAPI_KEY=CHANGE_ME

# ─── n8n DB (internal — SQLite default, swap if needed) ──────
# To use Postgres for n8n's own storage instead of SQLite:
# DB_TYPE=postgresdb
# DB_POSTGRESDB_HOST=localhost
# DB_POSTGRESDB_PORT=5432
# DB_POSTGRESDB_DATABASE=n8n
# DB_POSTGRESDB_USER=n8n_internal
# DB_POSTGRESDB_PASSWORD=CHANGE_ME
