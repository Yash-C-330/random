                      "position":  [
                                       2120,
                                       220
                                   ],
                      "parameters":  {
                                         "mode":  "runOnceForEachItem",
                                         "jsCode":  "const txt = .content?.[0]?.text || .body?.content?.[0]?.text || \u0027\u0027;\r\nlet parsed = null;\r\nlet valid = false;\r\nlet reason = \u0027\u0027;\r\ntry {\r\n  parsed = JSON.parse(txt);\r\n  valid = parsed \u0026\u0026 typeof parsed === \u0027object\u0027;\r\n} catch (e) {\r\n  reason = e.message;\r\n}\r\nreturn [{ json: { ..., parsed, valid, validation_reason: reason } }];"
                                     }
