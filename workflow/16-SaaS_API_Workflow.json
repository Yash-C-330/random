                                       720
                                   ],
                      "parameters":  {
                                         "operation":  "executeQuery",
                                         "query":  "SELECT * FROM public.agent_messages WHERE thread_id={{$json.params.thread_id}} ORDER BY created_at ASC LIMIT 200;"
                                     },
                      "credentials":  {
