                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       560,
                                       420
                                   ],
                      "parameters":  {
                                         "mode":  "runOnceForEachItem",
                                         "jsCode":  "const inKey = $json.headers?.[\"x-api-key\"] || $json.headers?.[\"X-API-KEY\"]; const ok = inKey \u0026\u0026 inKey === $env.SAAS_API_KEY; return [{ json: { ...$json, auth_ok: !!ok } }];"
                                     }
                  },
